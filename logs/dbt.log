        s.drivers_used,
        s.total_points,
        s.wins,
        s.podiums,
        s.fastest_laps,
        s.finish_rate_pct

    from constructors  c
    inner join season_stats s on c.constructor_id = s.constructor_id
)

select * from joined
    )

