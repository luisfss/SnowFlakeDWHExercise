[0m18:18:20.448657 [debug] [Thread-2 (]: On model.dwf1.dim_drivers: create or replace transient table DWF1.dev_marts.dim_drivers
    
    
    
    as (/*
  dim_drivers
  -----------
  Driver dimension enriched with season-level performance stats.
  Flat table intended for BI tools; no joins required on the dashboard side.
*/

with drivers as (
    select * from DWF1.dev_staging.stg_drivers
),

constructors as (
    select * from DWF1.dev_staging.stg_constructors
),

season_stats as (
    select * from DWF1.dev_intermediate.int_driver_season_stats
),

joined as (
    select
        md5(cast(coalesce(cast(d.driver_id as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(s.season as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as dim_driver_sk,

        d.driver_id,
        d.driver_code,
        d.full_name,
        d.nationality,
        d.date_of_birth,
        d.constructor_id,
        c.constructor_name,

        s.season,
        s.championship_position,
        s.races_entered,
        s.races_finished,
        s.total_points,
        s.wins,
        s.podiums,
        s.points_finishes,
        s.fastest_laps,
        s.finish_rate_pct,
        s.avg_finish_position,
        s.avg_grid_position

    from drivers        d
    inner join season_stats  s on d.driver_id      = s.driver_id
    inner join constructors  c on d.constructor_id = c.constructor_id
)

select * from joined
    )

